# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# These are overridden by docker-compose.yml environment section.
# Set here only when running outside compose (rare).
DATABASE_URL=postgres://expenses:expenses@postgres:5432/expenses_dev?sslmode=disable
TEST_DATABASE_URL=postgres://expenses:expenses@postgres:5432/expenses_test?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-minimum-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── App ───────────────────────────────────────────────────────────────────────
# Used to construct links in emails (verification, password reset, invitations)
BASE_URL=http://localhost:8080
